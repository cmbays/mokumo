{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-explicit-any": "error",
    "eqeqeq": "error"
  },
  "plugins": [],
  "ignorePatterns": [
    "build/",
    ".svelte-kit/",
    "node_modules/"
  ]
}
