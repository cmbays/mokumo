# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# gitnore
.gitignore

# next.js
.next/
out/

# production
build/

# misc
.DS_Store
*.tsbuildinfo
next-env.d.ts

# env — all .env* files; allow only documented example/template files
.env*
!.env.example
!.env.sample
!.env.template

# Claude Code
.claude/*
!.claude/skills/
!.claude/skills/**
!.claude/agents/
!.claude/agents/**
!.claude/hooks/
!.claude/hooks/**
!.claude/settings.json
.claudeignore

# ephemeral scratch space (delete at will — nothing here is committed)
tmp/

# Design mockup route — dev-only, never committed, never deployed
src/app/(dashboard)/mockup/

# secrets — private keys and certificates
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.crt
**/*.cer
**/*.jks
**/*.keystore

# secrets — credential and token files
credentials.json
service-account*.json
service_account*.json
secrets.json
secret.json
.npmrc
.netrc


# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# Quality gate screenshots (ephemeral, regenerated per audit)
quality-gate/

# Playwright MCP logs
.playwright-mcp/

# Per-worktree session files (never committed)
.session-context.md
.session-prompt.md
.session-launch.sh
.envrc
.claude-sessions.json

# Generated progress report (compiled artifact, not source of truth)
PROGRESS.md

# Supabase CLI local dev artifacts
.supabase/
supabase/.temp/

# Knowledge base build output
knowledge-base/dist/
knowledge-base/node_modules/
knowledge-base/.astro/
.firecrawl/

# dbt analytics (Python project in dbt/ directory)
dbt/.venv/
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/profiles/profiles.yml
dbt/profiles/.user.yml

# Playwright test artifacts (regenerated on each run)
playwright-report/
test-results/
tests/e2e/screenshots/

# Excalidraw desktop app logs
excalidraw.log

# Claude Code internal worktree-tracking state
.claire/
