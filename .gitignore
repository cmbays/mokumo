# ephemeral scratch space (delete at will — nothing here is committed)
tmp/

# Design mockup route — dev-only, never committed, never deployed
src/app/(dashboard)/mockup/

# secrets — private keys and certificates
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.crt
**/*.cer
**/*.jks
**/*.keystore

# secrets — SSH private keys (defense-in-depth against copy-paste accidents)
id_rsa
id_ed25519
id_ecdsa
id_dsa
*.ppk

# secrets — infrastructure state (contains embedded secrets and resource IDs)
*.tfstate
*.tfstate.backup
*.tfvars

# secrets — credential and token files
credentials.json
service-account*.json
service_account*.json
secrets.json
secret.json
application_default_credentials.json
token.json
.npmrc
.netrc


# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# Quality gate screenshots (ephemeral, regenerated per audit)
quality-gate/

# Playwright MCP logs
.playwright-mcp/

# Per-worktree session files (never committed)
.session-context.md
.session-prompt.md
.session-launch.sh
.envrc
.claude-sessions.json

# Generated progress report (compiled artifact, not source of truth)
PROGRESS.md

