{
  "name": "@mokumo/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "test:mutation": "stryker run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "pnpm exec bddgen && pnpm exec playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^0.577.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-svelte-csf": "^5.1.0",
    "@storybook/sveltekit": "10.3.3",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "bits-ui": "^2.16.3",
    "dependency-cruiser": "^17.3.9",
    "http-server": "^14.1.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "playwright-bdd": "^8.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "storybook": "10.3.3",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "packageManager": "pnpm@10.6.5"
}
