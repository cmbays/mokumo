{
  "$schema": "https://raw.githubusercontent.com/nickkelly1/tauri-docs/v2/tooling/cli/schema.json",
  "productName": "Mokumo",
  "identifier": "com.breezybayslabs.mokumo",
  "version": "0.1.0",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "resources": {
      "../../apps/web/scripts/demo.db": "demo.db"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
