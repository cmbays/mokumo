# =============================================================================
# Screen Print Pro — Environment Variables
# Copy this file to .env.local for local development.
# All required vars must be set in Vercel for Preview and Production.
# =============================================================================

# Demo access gate (required in all environments)
DEMO_ACCESS_CODE=your-access-code

# App base URL — used for email previews and absolute links
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Data provider: "mock" | "supabase"
DATA_PROVIDER=mock

# Supplier adapter: "mock" | "supabase-catalog" | "ss-activewear"
# "supabase-catalog" — normalized PostgreSQL catalog (default for deployed envs)
# "ss-activewear"   — live S&S API; requires SS_ACCOUNT_NUMBER + SS_API_KEY
# "mock"            — in-process fixture data; no credentials needed
SUPPLIER_ADAPTER=mock

# =============================================================================
# Supabase
# Local values in .env.local.example. Production/preview values from dashboard.
# =============================================================================
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/[db]
NEXT_PUBLIC_SUPABASE_URL=https://[project-id].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Protects POST /api/catalog/sync — server only
ADMIN_SECRET=your-admin-secret

# =============================================================================
# Upstash Redis (rate limiting + catalog cache)
# When both vars are set, UpstashCacheStore is used automatically.
# When absent, InMemoryCacheStore is used (no Redis required for local dev).
# =============================================================================
UPSTASH_REDIS_REST_URL=https://[id].upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# =============================================================================
# S&S Activewear API
# Required when SUPPLIER_ADAPTER=ss-activewear.
# Missing either var causes HTTP 500 on all supplier proxy routes.
# =============================================================================
SS_ACCOUNT_NUMBER=your-account-number
SS_API_KEY=your-api-key

# =============================================================================
# CI — GitHub Actions secrets
# These are NOT .env.local vars. Add them under:
# GitHub repo → Settings → Secrets and variables → Actions → Repository secrets
# =============================================================================
# VERCEL_TOKEN=your-vercel-personal-access-token   (Vercel → Account Settings → Tokens)
# VERCEL_ORG_ID=team_oZpFBCcctoxyVa4IQDkLMxr5      (from .vercel/project.json → orgId)
# VERCEL_PROJECT_ID=prj_8O8LT5YiKq0hFtPdrI828bQgKqeM (from .vercel/project.json → projectId)
