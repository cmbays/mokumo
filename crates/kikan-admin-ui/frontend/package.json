{
  "name": "@mokumo/kikan-admin-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "bddgen": "pnpm exec bddgen",
    "bdd-pr2a": "pnpm exec bddgen && pnpm exec playwright test --project pr2a --grep @pr2a",
    "screens": "pnpm exec bddgen && pnpm exec playwright test --project screens"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@lucide/svelte": "^1.8.0",
    "@playwright/test": "1.58.2",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/table-core": "^8.20.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.0",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "dependency-cruiser": "^17.3.9",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "playwright-bdd": "^8.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.0.0",
    "vite": "^6.4.2",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "mode-watcher": "^1.1.0",
    "runed": "0.37.1",
    "svelte-sonner": "^1.1.0",
    "zod": "^4.1.0"
  }
}
