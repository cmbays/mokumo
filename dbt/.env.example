# dbt PostgreSQL connection (Supabase direct connection — port 5432, NOT PgBouncer 6543)
#
# Local development (supabase start):
#   DBT_PG_HOST=127.0.0.1
#   DBT_PG_PORT=54322
#   DBT_PG_USER=postgres
#   DBT_PG_PASSWORD=postgres
#   DBT_PG_DATABASE=postgres
#
# Remote Supabase:
#   DBT_PG_HOST=db.<project-ref>.supabase.co
#   DBT_PG_PORT=5432
#   DBT_PG_USER=postgres.<project-ref>
#   DBT_PG_PASSWORD=<your-db-password>
#   DBT_PG_DATABASE=postgres

DBT_PG_HOST=127.0.0.1
DBT_PG_PORT=54322
DBT_PG_USER=postgres
DBT_PG_PASSWORD=postgres
DBT_PG_DATABASE=postgres
